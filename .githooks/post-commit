#!/bin/sh
# Remove build artifacts (bin/, obj/) older than 7 days after each commit.
# Enable hooks: git config core.hooksPath .githooks

ROOT="$(git rev-parse --show-toplevel)" || exit 0

for dir in bin obj; do
  [ -d "$ROOT/$dir" ] || continue
  find "$ROOT/$dir" -type f -mtime +7 -delete 2>/dev/null
  find "$ROOT/$dir" -depth -type d -empty -delete 2>/dev/null
done

exit 0
